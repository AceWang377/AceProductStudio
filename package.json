{
  "name": "ai-product-studio",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web && node scripts/sync-vercel-output.mjs",
    "vercel-build": "npm run build -w apps/web && node scripts/sync-vercel-output.mjs",
    "lint": "npm run lint -w apps/web",
    "prisma:generate": "npm run prisma:generate -w packages/database",
    "prisma:migrate": "npm run prisma:migrate -w packages/database"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "bullmq": "^5.51.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "postcss": "^8.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
